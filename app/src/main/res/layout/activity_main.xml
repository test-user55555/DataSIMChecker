<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ヘッダー -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📡 SIM回線モニター"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 権限警告 -->
        <TextView
            android:id="@+id/tvPermissionWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@drawable/card_warning"
            android:textColor="@color/warning_text"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- ==========================================
             アクティブSIM メインカード
             ========================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_main"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <!-- ラベル行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvActiveSimLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="アクティブ回線"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <!-- SIMタイプバッジ -->
                <TextView
                    android:id="@+id/tvActiveSimType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="eSIM"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/badge_esim" />
            </LinearLayout>

            <!-- キャリア名（SIM設定名・サブテキスト） -->
            <TextView
                android:id="@+id/tvCarrierName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="2dp" />

            <!-- プロバイダ名（実際の通信回線、minsoku.net取得） -->
            <TextView
                android:id="@+id/tvProviderName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="取得中..."
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <!-- ネットワーク種別・電波 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvNetworkType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="16sp"
                    android:textColor="@color/accent_blue"
                    android:textStyle="bold"
                    android:paddingEnd="16dp" />

                <TextView
                    android:id="@+id/tvSignalStrength"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="▂▄▆█"
                    android:textSize="18sp"
                    android:textColor="@color/active_green" />

                <TextView
                    android:id="@+id/tvConnectionType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="接続: ---"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- ローミング警告 -->
            <TextView
                android:id="@+id/tvRoamingWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ ローミング中"
                android:textSize="13sp"
                android:textColor="@color/warning_text"
                android:visibility="gone"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- ==========================================
             SIM一覧セクション
             ========================================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SIM一覧"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <!-- SIM 1 カード -->
        <LinearLayout
            android:id="@+id/cardSim1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_inactive"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvSim1Name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SIM 1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvSim1Type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💳 物理SIM"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvSim1Status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="○ 待機中"
                        android:textSize="13sp"
                        android:textColor="@color/inactive_gray" />

                    <TextView
                        android:id="@+id/tvSim1Signal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="░░░░"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- SIM 2 カード -->
        <LinearLayout
            android:id="@+id/cardSim2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_inactive"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvSim2Name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SIM 2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvSim2Type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔷 eSIM"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvSim2Status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="○ 待機中"
                        android:textSize="13sp"
                        android:textColor="@color/inactive_gray" />

                    <TextView
                        android:id="@+id/tvSim2Signal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="░░░░"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ==========================================
             サービス制御ボタン + 情報更新ボタン
             ========================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnStartService"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ 監視開始"
                android:textSize="14sp"
                android:backgroundTint="@color/accent_blue"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnStopService"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="■ 監視停止"
                android:textSize="14sp"
                android:backgroundTint="@color/inactive_gray"
                android:enabled="false" />
        </LinearLayout>

        <!-- 情報更新ボタン（プロバイダを再取得する） -->
        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 情報更新（プロバイダ再取得）"
            android:textSize="15sp"
            android:backgroundTint="#2E7D32"
            android:enabled="false"
            android:layout_marginBottom="12dp" />

        <!-- 最終更新時刻 -->
        <TextView
            android:id="@+id/tvLastUpdated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="更新: --:--:--"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- ==========================================
             ログエリア（デバッグ用）
             ========================================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 通信ログ"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvLogArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:padding="12dp"
            android:background="#1A1A2E"
            android:textColor="#A8D8A8"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="ログ待機中..."
            android:layout_marginBottom="12dp" />

        <!-- 説明テキスト -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 ホームスクリーンにウィジェットを追加すると、リアルタイムで回線状態を確認できます"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
