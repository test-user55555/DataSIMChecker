<?xml version="1.0" encoding="utf-8"?>
<!-- ホームスクリーンウィジェット – プロバイダ名を最大フォントで中央表示 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- 背景レイヤー（SIMタイプで色が変わる） -->
    <LinearLayout
        android:id="@+id/widgetBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/widget_bg_unknown"
        android:gravity="center_vertical">

        <!-- ── 上段: SIMタイプバッジ ＋ 更新ボタン ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <!-- SIMタイプ（eSIM / 物理SIM / WiFi / 未接続） -->
            <TextView
                android:id="@+id/tvWidgetSimType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="---"
                android:textSize="11sp"
                android:textColor="#CCFFFFFF"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <!-- 手動更新ボタン -->
            <TextView
                android:id="@+id/btnWidgetRefresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↺"
                android:textSize="15sp"
                android:textColor="#AAFFFFFF"
                android:padding="4dp" />
        </LinearLayout>

        <!-- ── メイン: プロバイダ名（最大・最目立つ） ── -->
        <TextView
            android:id="@+id/tvWidgetProvider"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="---"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:singleLine="true"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:includeFontPadding="false" />

        <!-- ── 下段: キャリア設定名 ＋ ネットワーク種別 ＋ 電波 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <!-- キャリア設定名（SIM設定で付けた名前） -->
            <TextView
                android:id="@+id/tvWidgetCarrier"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="---"
                android:textSize="10sp"
                android:textColor="#99FFFFFF"
                android:singleLine="true"
                android:ellipsize="end" />

            <!-- ネットワーク種別（5G/LTE 等） -->
            <TextView
                android:id="@+id/tvWidgetNetwork"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="11sp"
                android:textColor="#CCFFFFFF"
                android:textStyle="bold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp" />

            <!-- 電波強度 -->
            <TextView
                android:id="@+id/tvWidgetSignal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▂▄▆█"
                android:textSize="11sp"
                android:textColor="#CCFFFFFF"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ── 最終更新時刻（右寄せ小文字） ── -->
        <TextView
            android:id="@+id/tvWidgetTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--:--:--"
            android:textSize="8sp"
            android:textColor="#77FFFFFF"
            android:gravity="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>
