<?xml version="1.0" encoding="utf-8"?>
<!--
  au 通知バーアイコン（白単色 24×24dp）
  太字サンセリフ体で "au" を表現
  小さいサイズでも視認できるよう、シンプルな塗り文字スタイル
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
      "a" : 丸いオープン形状（左上から時計回りの楕円 + 右縦棒）
      中心 (6.5, 14), r≒5.5
    -->
    <!-- a の外周（塗り） -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="
          M 6.5,8
          C 3.2,8 1,10.5 1,14
          C 1,17.5 3.2,20 6.5,20
          C 8.6,20 10.2,19 11,17.5
          L 11,20
          L 13,20
          L 13,8
          L 11,8
          L 11,10.5
          C 10.2,9 8.6,8 6.5,8
          Z
          M 6.5,18
          C 4.3,18 3,16.4 3,14
          C 3,11.6 4.3,10 6.5,10
          C 8.7,10 10,11.6 10,14
          C 10,16.4 8.7,18 6.5,18
          Z
        "/>

    <!--
      "u" : 下開きのU字（左縦棒 + 底カーブ + 右縦棒）
    -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="
          M 15,8
          L 15,16
          C 15,17.7 16.1,18 17,18
          C 17.9,18 19,17.7 19,16
          L 19,8
          L 21,8
          L 21,16
          C 21,18.8 19.3,20 17,20
          C 14.7,20 13,18.8 13,16
          L 13,8
          Z
        "/>
</vector>
