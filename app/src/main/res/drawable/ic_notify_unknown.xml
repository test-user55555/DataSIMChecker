<?xml version="1.0" encoding="utf-8"?>
<!--
  未接続・不明アイコン（通知バー用・白単色 24×24dp）
  スラッシュ（/）付き電波バーで「接続なし」を表現
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- 電波バー 1（最小） -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M2,20 L5,20 L5,22 L2,22 Z"/>

    <!-- 電波バー 2 -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M7,16 L10,16 L10,22 L7,22 Z"/>

    <!-- 電波バー 3（斜線で打ち消し） -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,12 L15,12 L15,22 L12,22 Z"
        android:alpha="0.35"/>

    <!-- 電波バー 4（斜線で打ち消し） -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M17,8 L20,8 L20,22 L17,22 Z"
        android:alpha="0.35"/>

    <!-- 斜線（バー3・4にかかる否定スラッシュ） -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M11,16.5 L13,14.5 L21,22.5 L19,24.5 Z"/>
</vector>
